# HTTP server
PORT=3000

# Worker: cron schedule (6 fields: sec min hour day month weekday)
# Default: every 10 seconds
COMPARE_CRON=*/10 * * * * *

# Timeout for each feed fetch, in milliseconds
FETCH_TIMEOUT_MS=20000

# Redis connection URL (optional — app runs without it).
# On Railway, set this to a reference variable: ${{Redis.REDIS_URL}}
# Local example: redis://localhost:6379
# REDIS_URL=
