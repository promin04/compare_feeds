# HTTP server
PORT=3000

# Worker: cron schedule (6 fields: sec min hour day month weekday)
# Default: every 10 seconds
COMPARE_CRON=*/10 * * * * *

# Timeout for each feed fetch, in milliseconds
FETCH_TIMEOUT_MS=20000

# Redis connection URL (optional — app runs without it).
# On Railway, set this to a reference variable: ${{Redis.REDIS_URL}}
# Local example: redis://localhost:6379
# REDIS_URL=

# Timezone for bucketing events into local days/hours (heatmap)
TZ_NAME=Asia/Bangkok

# Heatmap window (days back) and how long data is kept (days)
HEATMAP_DAYS=5
RETENTION_DAYS=6

# Allowed CORS origins for the frontend (comma-separated).
# Empty = reflect any origin (dev only). Lock down in production.
# CORS_ORIGIN=https://your-frontend.up.railway.app,http://localhost:5173
